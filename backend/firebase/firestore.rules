rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // User profile lock settings
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Doubts wall allow anonymous reading and secured write policies
    match /doubts/{doubtId} {
      allow read: if true; // Open reading to support community learning pathways
      allow create: if true; // Support quick anonymous submissions
      allow update: if request.auth != null; // Restrict updates to active authenticated users
    }

    // Lessons catalog read rules
    match /lessons/{lessonId} {
      allow read: if true; // Public access for reading lessons
      allow write: if request.auth != null && request.auth.token.admin == true; // Only admins can update the lesson bank
    }
  }
}